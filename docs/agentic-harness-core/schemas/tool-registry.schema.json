{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ToolRegistry",
  "type": "object",
  "required": ["id", "name", "owner", "endpoint", "dataClass", "policyProfile", "version"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$"
    },
    "name": { "type": "string" },
    "owner": { "type": "string" },
    "endpoint": { "type": "string", "format": "uri" },
    "dataClass": {
      "type": "string",
      "enum": ["model", "evidence", "rag", "graph", "parser", "generator", "test", "other"]
    },
    "policyProfile": { "type": "string" },
    "version": { "type": "string" },
    "description": { "type": "string" }
  },
  "additionalProperties": false
}
