{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CapabilityCatalog",
  "type": "object",
  "required": ["capability"],
  "properties": {
    "callerRole": {
      "type": "string",
      "enum": ["agent", "orchestrator", "workflow", "service"],
      "deprecated": true,
      "description": "Ignored by the service. The caller role is derived from the authenticated X-Harness-Role header."
    },
    "capability": {
      "type": "object",
      "required": ["id", "name", "owner", "endpoint", "dataClass", "policyProfile", "version"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$"
        },
        "name": { "type": "string" },
        "owner": { "type": "string" },
        "endpoint": { "type": "string", "format": "uri" },
        "dataClass": { "type": "string" },
        "policyProfile": { "type": "string" },
        "version": { "type": "string" },
        "description": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
