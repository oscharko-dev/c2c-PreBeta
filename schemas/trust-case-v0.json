{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oscharko.dev/c2c/schemas/trust-case-v0.json",
  "title": "C2C Trust Case Catalog v0",
  "description": "Immutable repo-owned trust-case catalog for parity-aware Studio transformations. Browser clients may select a trustCaseId, but runtime parameters, environment profile metadata, comparison strategy, and evidence identity are resolved from this catalog by trusted services.",
  "type": "object",
  "required": ["schemaVersion", "catalogVersion", "trustCases"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "v0"
    },
    "catalogVersion": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "trustCases": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/trustCase" }
    }
  },
  "$defs": {
    "trustCase": {
      "type": "object",
      "required": [
        "trustCaseId",
        "version",
        "programId",
        "title",
        "description",
        "defaultForProgram",
        "sourceReference",
        "controlledInput",
        "runtime",
        "environmentProfile",
        "comparison",
        "supportedProgramShape",
        "evidenceIdentity"
      ],
      "additionalProperties": false,
      "properties": {
        "trustCaseId": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9-]{1,63}$"
        },
        "version": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
        },
        "programId": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9-]{0,63}$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "defaultForProgram": {
          "type": "boolean"
        },
        "sourceReference": {
          "type": "object",
          "required": ["fixtureId", "mode"],
          "additionalProperties": false,
          "properties": {
            "fixtureId": {
              "type": "string",
              "pattern": "^[A-Z][A-Z0-9-]{1,63}$"
            },
            "mode": {
              "type": "string",
              "enum": ["reference-fixture", "native-cobol"]
            }
          }
        },
        "controlledInput": {
          "type": "object",
          "required": ["stdin", "dataSetIds", "expectedOutputFixtureId"],
          "additionalProperties": false,
          "properties": {
            "stdin": {
              "type": ["string", "null"],
              "maxLength": 8192
            },
            "dataSetIds": {
              "type": "array",
              "maxItems": 16,
              "uniqueItems": true,
              "items": {
                "type": "string",
                "pattern": "^[A-Z][A-Z0-9_-]{1,63}$"
              }
            },
            "expectedOutputFixtureId": {
              "type": "string",
              "pattern": "^[A-Z][A-Z0-9-]{1,63}$"
            }
          }
        },
        "runtime": {
          "type": "object",
          "required": ["programArgs"],
          "additionalProperties": false,
          "properties": {
            "programArgs": {
              "type": "array",
              "maxItems": 8,
              "items": {
                "type": "string",
                "maxLength": 80,
                "pattern": "^[A-Za-z0-9._:=@/+,-]*$",
                "not": {
                  "anyOf": [
                    { "pattern": "\\.\\." },
                    { "pattern": "^/" },
                    { "pattern": "^[A-Za-z]:[\\\\/]" }
                  ]
                }
              }
            }
          }
        },
        "environmentProfile": {
          "type": "object",
          "required": ["profileId", "description", "variables"],
          "additionalProperties": false,
          "properties": {
            "profileId": {
              "type": "string",
              "enum": ["generated-java-sandbox-v1", "reference-fixture-v1", "native-cobol-controlled-v1"]
            },
            "description": {
              "type": "string",
              "minLength": 1
            },
            "variables": {
              "type": "object",
              "propertyNames": {
                "pattern": "^[A-Z][A-Z0-9_]{0,63}$"
              },
              "additionalProperties": {
                "type": "string",
                "pattern": "^[A-Za-z0-9._:/=+\\-]{0,256}$"
              }
            }
          }
        },
        "comparison": {
          "type": "object",
          "required": ["strategy", "policyVersion"],
          "additionalProperties": false,
          "properties": {
            "strategy": {
              "type": "string",
              "enum": ["deterministic-output"]
            },
            "policyVersion": {
              "type": "string",
              "const": "deterministic-output-v1"
            }
          }
        },
        "supportedProgramShape": {
          "type": "object",
          "required": ["language", "programId", "supportedSubset"],
          "additionalProperties": false,
          "properties": {
            "language": {
              "type": "string",
              "const": "cobol"
            },
            "programId": {
              "type": "string",
              "pattern": "^[A-Z][A-Z0-9-]{0,63}$"
            },
            "supportedSubset": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true
            }
          }
        },
        "evidenceIdentity": {
          "type": "object",
          "required": ["kind", "artifactName"],
          "additionalProperties": false,
          "properties": {
            "kind": {
              "type": "string",
              "const": "trust-case"
            },
            "artifactName": {
              "type": "string",
              "const": "executed-trust-case.json"
            }
          }
        }
      }
    }
  }
}
