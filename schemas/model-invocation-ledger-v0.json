{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oscharko.dev/c2c/schemas/model-invocation-ledger-v0.json",
  "title": "Model Invocation Ledger v0",
  "type": "object",
  "required": [
    "schemaVersion",
    "invocationId",
    "runId",
    "modelId",
    "provider",
    "policyId",
    "dataClass",
    "promptTemplateVersion",
    "policyDecision",
    "status",
    "latencyMs",
    "requestRef",
    "outputRef",
    "createdAt"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "v0"
    },
    "invocationId": {
      "type": "string",
      "minLength": 1
    },
    "runId": {
      "type": "string",
      "minLength": 1
    },
    "modelId": {
      "type": "string",
      "minLength": 1
    },
    "provider": {
      "type": "string",
      "enum": ["foundry-development", "customer-internal-mock"]
    },
    "policyId": {
      "type": "string",
      "minLength": 1,
      "description": "Active gateway policy version, e.g. foundry-development-v0. Recorded by the gateway on every invocation (Issue #168)."
    },
    "agentRole": {
      "type": "string",
      "minLength": 1,
      "description": "W0.2 agent role attributed to the invocation, e.g. \"transformation\" or \"verification-repair\". Omitted when the caller did not stamp a role."
    },
    "usage": {
      "type": "object",
      "description": "Token usage reported by the upstream provider. Optional because not every provider returns usage counts.",
      "properties": {
        "prompt_tokens": { "type": ["integer", "number"], "minimum": 0 },
        "completion_tokens": { "type": ["integer", "number"], "minimum": 0 },
        "total_tokens": { "type": ["integer", "number"], "minimum": 0 }
      },
      "additionalProperties": true
    },
    "errorCode": {
      "type": "string",
      "minLength": 1,
      "description": "Structured error code (Issue #168). Set to malformed_request / model_policy_denied / model_provider_unavailable / model_provider_timeout / model_provider_error when the request fails; absent on success."
    },
    "dataClass": {
      "type": "string",
      "enum": ["model", "evidence", "rag", "graph", "parser", "generator", "build-test", "test", "model-gateway", "other"]
    },
    "promptTemplateVersion": {
      "type": "string",
      "minLength": 1
    },
    "policyDecision": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["completed", "failed", "rejected"]
    },
    "latencyMs": {
      "type": "integer",
      "minimum": 0
    },
    "requestRef": { "$ref": "#/$defs/dataReference" },
    "outputRef": { "$ref": "#/$defs/dataReference" },
    "errorClass": {
      "type": "string",
      "minLength": 1
    },
    "errorMessage": {
      "type": "string",
      "minLength": 1
    },
    "parameters": {
      "type": "object"
    },
    "structuredOutput": {
      "type": "boolean"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": true,
  "$defs": {
    "dataReference": {
      "type": "object",
      "required": ["uri", "sha256", "byteSize"],
      "properties": {
        "uri": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-fA-F]{64}$"
        },
        "byteSize": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    }
  }
}
