{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oscharko.dev/c2c/schemas/agent-trajectory-ledger-v0.json",
  "title": "Agent Trajectory Ledger v0",
  "type": "object",
  "required": [
    "schemaVersion",
    "runId",
    "status",
    "capturedAt",
    "steps"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "v0"
    },
    "runId": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "workflowId": {
      "type": "string",
      "minLength": 1
    },
    "startedAt": {
      "type": "string",
      "format": "date-time"
    },
    "completedAt": {
      "type": "string",
      "format": "date-time"
    },
    "capturedAt": {
      "type": "string",
      "format": "date-time"
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "eventId",
          "stepId",
          "actor",
          "capability",
          "dataClass",
          "eventType",
          "stateTransition",
          "status",
          "createdAt"
        ],
        "properties": {
          "eventId": {
            "type": "string",
            "minLength": 1
          },
          "stepId": {
            "type": "integer",
            "exclusiveMinimum": 0
          },
          "actor": {
            "type": "string",
            "minLength": 1
          },
          "capability": {
            "type": "string",
            "minLength": 1
          },
          "dataClass": {
            "type": "string",
            "enum": ["model", "evidence", "rag", "graph", "parser", "generator", "build-test", "test", "model-gateway", "other"]
          },
          "eventType": {
            "type": "string",
            "minLength": 1
          },
          "stateTransition": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "minLength": 1
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": true
}
