{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oscharko.dev/c2c/schemas/build-test-result-v0.json",
  "title": "Build/Test Result v0",
  "description": "Structured envelope produced by build-test-runner-service for one verification of a generated target-language project against a Golden Master.",
  "type": "object",
  "required": [
    "schemaVersion",
    "capability",
    "service",
    "programId",
    "status",
    "classification",
    "outputRef"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "v0"
    },
    "capability": {
      "type": "string",
      "const": "build-test.run"
    },
    "service": {
      "type": "string",
      "minLength": 1
    },
    "runId": {
      "type": "string"
    },
    "workflowId": {
      "type": "string"
    },
    "sourceRef": {
      "type": "object"
    },
    "programId": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "ok",
        "compile-failed",
        "run-failed",
        "output-divergence",
        "golden-master-reproduction-failed",
        "missing-golden-master",
        "skipped"
      ]
    },
    "classification": {
      "type": "string",
      "enum": [
        "match",
        "divergence-known-w0-coverage-gap",
        "divergence-unknown",
        "true-golden-master-reproduction-error",
        "true-golden-master-mismatch",
        "compile-error",
        "run-error",
        "skipped-no-execution",
        "missing-golden-master"
      ]
    },
    "summary": {
      "type": "string"
    },
    "build": {
      "type": "object",
      "properties": {
        "compileOk": { "type": "boolean" },
        "sourceCount": { "type": "integer", "minimum": 0 },
        "fileCount": { "type": "integer", "minimum": 0 },
        "diagnostics": { "type": "array" }
      }
    },
    "execution": {
      "type": "object",
      "properties": {
        "ran": { "type": "boolean" },
        "ok": { "type": "boolean" },
        "exitCode": { "type": "integer" },
        "stdout": { "type": "string" },
        "stderr": { "type": "string" },
        "durationMs": { "type": "integer", "minimum": 0 },
        "stdoutSha256": {
          "type": "string",
          "pattern": "^[0-9a-fA-F]{64}$"
        }
      }
    },
    "tests": {
      "type": "object"
    },
    "goldenMaster": {
      "type": "object",
      "properties": {
        "programId": { "type": "string" },
        "expected": { "type": "string" },
        "expectedSha256": {
          "type": "string",
          "pattern": "^[0-9a-fA-F]{64}$"
        },
        "classification": {
          "type": "string",
          "enum": ["true", "synthetic"]
        },
        "source": { "type": "string" },
        "cobolSource": { "type": "string" },
        "knownDivergenceAtW0": { "type": "boolean" },
        "cobolRuntime": {
          "type": "object",
          "properties": {
            "attempted": { "type": "boolean" },
            "available": { "type": "boolean" },
            "compileOk": { "type": "boolean" },
            "ran": { "type": "boolean" },
            "ok": { "type": "boolean" },
            "matched": { "type": "boolean" },
            "compileExitCode": { "type": "integer" },
            "exitCode": { "type": "integer" },
            "stdout": { "type": "string" },
            "stderr": { "type": "string" },
            "stdoutSha256": {
              "type": "string",
              "pattern": "^[0-9a-fA-F]{64}$"
            },
            "durationMs": { "type": "integer", "minimum": 0 },
            "reason": { "type": "string" },
            "programId": { "type": "string" },
            "cobolSource": { "type": "string" },
            "moduleName": { "type": "string" },
            "compiler": { "type": "string" },
            "runtime": { "type": "string" },
            "cobcVersion": { "type": "string" },
            "cobcrunVersion": { "type": "string" }
          }
        }
      }
    },
    "comparison": {
      "type": "object",
      "properties": {
        "matched": { "type": "boolean" },
        "actualSha256": {
          "type": "string",
          "pattern": "^[0-9a-fA-F]{64}$"
        },
        "expectedSha256": {
          "type": "string",
          "pattern": "^[0-9a-fA-F]{64}$"
        }
      }
    },
    "oracleComparison": {
      "type": "object",
      "description": "W0.2 — explicit comparison artifact bundling the oracle source, expected output, actual output, and match outcome. Intended for inclusion in the Evidence Pack so reviewers can re-run the comparison without re-reading service internals. Always present when the runner had an oracle available; matched=false implies the run cannot be classified as success at the evidence layer.",
      "required": ["matched", "oracleKind"],
      "properties": {
        "matched": { "type": "boolean" },
        "oracleKind": {
          "type": "string",
          "enum": ["cobol-runtime", "synthetic", "true-golden-master", "absent"]
        },
        "expectedSha256": {
          "type": "string",
          "pattern": "^[0-9a-fA-F]{64}$"
        },
        "actualSha256": {
          "type": "string",
          "pattern": "^[0-9a-fA-F]{64}$"
        },
        "summary": { "type": "string" },
        "classification": { "type": "string" }
      },
      "additionalProperties": true
    },
    "outputRef": {
      "type": "object",
      "required": ["uri", "sha256", "byteSize"],
      "properties": {
        "uri": { "type": "string", "minLength": 1 },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-fA-F]{64}$"
        },
        "byteSize": { "type": "integer", "minimum": 0 },
        "mimeType": { "type": "string" },
        "kind": { "type": "string" }
      }
    },
    "diagnostics": {
      "type": "array",
      "items": { "$ref": "#/$defs/Diagnostic" }
    }
  },
  "additionalProperties": true,
  "$defs": {
    "Diagnostic": {
      "type": "object",
      "description": "BFF-shaped diagnostic record. Governed by ADR 0006 (Studio-BFF Contract Versioning). schemaVersion is optional on the wire; absence means 'v0'. All positional fields and artifactRef are optional per the additive-only rule.",
      "required": ["severity", "code", "message"],
      "properties": {
        "schemaVersion": {
          "type": "string",
          "enum": ["v0"]
        },
        "severity": { "type": "string" },
        "code": { "type": "string" },
        "message": { "type": "string" },
        "line": { "type": ["integer", "null"], "minimum": 1 },
        "column": { "type": ["integer", "null"], "minimum": 1 },
        "endLine": { "type": ["integer", "null"], "minimum": 1 },
        "endColumn": { "type": ["integer", "null"], "minimum": 1 },
        "filePath": { "type": ["string", "null"] },
        "sourceKind": {
          "type": ["string", "null"],
          "enum": ["cobol", "ir", "generated_java", "build", "test", null]
        },
        "originStep": { "type": ["string", "null"] },
        "artifactRef": {
          "type": ["object", "null"],
          "description": "Reference to the artifact this diagnostic attaches to (sha256, kind, optional path). Absent on diagnostics from older steps or replayed v0 fixtures."
        }
      },
      "additionalProperties": true
    }
  }
}
