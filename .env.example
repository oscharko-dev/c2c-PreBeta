# c2c local product-mode launcher
C2C_LOCAL_VAR_DIR=var/c2c-local
C2C_LOCAL_READY_MARKER=var/c2c-local/ready
C2C_LOCAL_HARNESS_PORT=18080
C2C_LOCAL_EVIDENCE_PORT=18081
C2C_LOCAL_EXPERIENCE_PORT=18082
C2C_LOCAL_PARSER_PORT=18083
C2C_LOCAL_SEMANTIC_IR_PORT=18084
C2C_LOCAL_TARGET_JAVA_GENERATION_PORT=18085
C2C_LOCAL_BUILD_TEST_RUNNER_PORT=18086
C2C_LOCAL_MODEL_GATEWAY_PORT=18087
C2C_LOCAL_ORCHESTRATOR_PORT=18088
C2C_LOCAL_BFF_PORT=18089
C2C_LOCAL_HARNESS_TOKEN=c2c-local-control-plane-token
C2C_LOCAL_MODEL_GATEWAY_ENABLED=0

# Orchestrator run-scoped artifact persistence (Issue #89).
# Each transformation run is materialized under {C2C_RUN_ARTIFACT_ROOT}/{runId}/
# with source.cbl, parse-output.json, semantic-ir.json, generated-project/,
# build-test-result.json, evidence-pack-manifest.json, trajectory-ledger.json,
# model-invocation-ledger.json|model-policy-skipped.json, and run-summary.json.
C2C_RUN_ARTIFACT_ROOT=var/c2c-local/runs
ORCHESTRATOR_MODEL_GATEWAY_MODEL_ID=gpt-oss-120b
ORCHESTRATOR_MODEL_POLICY_VERSION=v0

# Model Gateway local runtime
MODEL_GATEWAY_MODEL_REGISTRY_PATH=config/model-registry.example.yaml
MODEL_GATEWAY_ALLOWLIST_PATH=config/foundry-development-allowlist-v0.yaml
MODEL_GATEWAY_LEDGER_PATH=data/model-invocation-ledger-v0.jsonl
MODEL_GATEWAY_EVENT_LOG_PATH=data/model-gateway-events-v0.jsonl
MODEL_GATEWAY_LISTEN_ADDR=:8085

# Required for Azure Foundry-backed W0 development
C2C_MODEL_PROVIDER=azure_foundry
AZURE_FOUNDRY_ENDPOINT=https://workspacedevfoundrywnal9xa1.cognitiveservices.azure.com/openai/deployments
# Set either AZURE_FOUNDRY_API_KEY (local secret) or AZURE_FOUNDRY_API_KEY_REF.
AZURE_FOUNDRY_API_KEY=
AZURE_FOUNDRY_API_KEY_REF=
AZURE_FOUNDRY_API_VERSION=2024-05-01-preview
C2C_MODEL_DEFAULT_DEPLOYMENT=gpt-oss-120b
C2C_MODEL_FALLBACK_DEPLOYMENTS=mistral-large-3,phi-4,phi-4-mini-instruct
C2C_MODEL_ALLOWED_DEPLOYMENTS=gpt-oss-120b,mistral-large-3,phi-4,phi-4-mini-instruct
C2C_MODEL_DATA_POLICY=public_synthetic_only
C2C_MODEL_INVOCATION_LEDGER_ENABLED=true
C2C_HARNESS_EVENT_EMISSION_ENABLED=true

# Next.js UI Configuration
NEXT_PUBLIC_C2C_BFF_BASE_URL=http://localhost:18089
