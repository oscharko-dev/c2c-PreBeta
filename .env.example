# Model Gateway local runtime
MODEL_GATEWAY_MODEL_REGISTRY_PATH=config/model-registry.example.yaml
MODEL_GATEWAY_ALLOWLIST_PATH=config/foundry-development-allowlist-v0.yaml
MODEL_GATEWAY_LEDGER_PATH=data/model-invocation-ledger-v0.jsonl
MODEL_GATEWAY_EVENT_LOG_PATH=data/model-gateway-events-v0.jsonl
MODEL_GATEWAY_LISTEN_ADDR=:8085

# Required for Azure Foundry-backed W0 development
C2C_MODEL_PROVIDER=azure_foundry
AZURE_FOUNDRY_ENDPOINT=https://workspacedevfoundrywnal9xa1.cognitiveservices.azure.com/openai/deployments
# Set either AZURE_FOUNDRY_API_KEY (local secret) or AZURE_FOUNDRY_API_KEY_REF.
AZURE_FOUNDRY_API_KEY=
AZURE_FOUNDRY_API_KEY_REF=
AZURE_FOUNDRY_API_VERSION=2024-05-01-preview
C2C_MODEL_DEFAULT_DEPLOYMENT=gpt-oss-120b
C2C_MODEL_FALLBACK_DEPLOYMENTS=mistral-large-3,phi-4,phi-4-mini-instruct
C2C_MODEL_ALLOWED_DEPLOYMENTS=gpt-oss-120b,mistral-large-3,phi-4,phi-4-mini-instruct
C2C_MODEL_DATA_POLICY=public_synthetic_only
C2C_MODEL_INVOCATION_LEDGER_ENABLED=true
C2C_HARNESS_EVENT_EMISSION_ENABLED=true
