# Ruby
# -------------------------------
.bundle/
vendor/bundle/
log/
.byebug_history

# -------------------------------
# Go
# -------------------------------
bin/
.go-version
# Service binaries built in-place by `go build` (no extension on Unix,
# named after the containing directory). Listed explicitly because a
# wildcard pattern would risk matching real source paths.
/services/agentic-harness-core/agentic-harness-core
/services/evidence-service/evidence-service
/services/model-gateway-service/model-gateway-service

# -------------------------------
# .NET
# -------------------------------
bin/
obj/
.vs/

# -------------------------------
# Rust
# -------------------------------
target/

# -------------------------------
# Re-include source paths that legitimately contain a 'target' segment
# (e.g. Java packages com.c2c.target.* shipped under libs/) so the
# language-build rules above do not swallow real source.
# -------------------------------
!libs/**/src/main/java/**/target/
!libs/**/src/main/java/**/target/**
!libs/**/src/test/java/**/target/
!libs/**/src/test/java/**/target/**

