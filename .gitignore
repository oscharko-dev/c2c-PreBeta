services/evidence-service/data/

# W0 reference run orchestrator output (logs, captured artifacts, exports, ledgers).
# Reproducible from `scripts/w0-reference-run.sh`; never commit these.
var/

# Local generated supply-chain/build outputs
artifacts/*.json
**/dependency-reduced-pom.xml

# TypeScript test transpilation output
apps/c2c-studio/dist-test/

# Markdown link-checker cache (regenerated on every lychee run)
.lycheecache
/qodana/
