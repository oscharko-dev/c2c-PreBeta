{
  "name": "c2c-studio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:perf": "NEXT_PUBLIC_C2C_PERF_HARNESS=1 next build",
    "start": "next start",
    "start:perf": "NEXT_PUBLIC_C2C_PERF_HARNESS=1 next start",
    "lint": "eslint .",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ci": "playwright test --grep-invert \"@visual|@perf|@memory|@csp\"",
    "test:e2e:update-snapshots": "playwright test --grep @visual --update-snapshots",
    "test:e2e:a11y": "playwright test --grep @a11y",
    "test:e2e:a11y:ci": "playwright test --config=playwright.a11y.config.ts",
    "test:e2e:perf": "npm run build:perf && playwright test --config=playwright.studio-only.config.ts --grep @perf",
    "test:e2e:memory": "npm run build:perf && playwright test --config=playwright.studio-only.config.ts --grep @memory",
    "test:e2e:csp": "playwright test --grep @csp",
    "test:e2e:csp:ci": "playwright test --config=playwright.csp.config.ts",
    "verify:monaco-lazy": "node scripts/verify-monaco-lazy.mjs"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "autoprefixer": "^10.4.19",
    "clsx": "^2.1.1",
    "dompurify": "^3.4.5",
    "idb": "^8.0.0",
    "lucide-react": "^0.378.0",
    "marked": "^14.1.4",
    "monaco-editor": "^0.55.1",
    "next": "^16.2.6",
    "postcss": "8.5.10",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.3.0",
    "tailwindcss": "^3.4.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.0.0",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^15.0.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.12.7",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "fake-indexeddb": "^6.0.0",
    "jsdom": "^24.0.0",
    "typescript": "^5.4.5",
    "vitest": "^3.2.0"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
